---
/**
 * About page
 * URL: /about
 */
import PageLayout from '@/layouts/PageLayout.astro';
import Icon from '@/components/ui/primitives/Icon/Icon.astro';
import Badge from '@/components/ui/data-display/Badge/Badge.astro';
import Card from '@/components/ui/data-display/Card/Card.astro';
import Button from '@/components/ui/form/Button/Button.astro';
import { Hero } from '@/components/hero';
import TypingEffect from '@/components/ui/TypingEffect.astro';
import TechStack from '@/components/landing/TechStack.astro';
---
<PageLayout
  title="About Nazar Hnatyuk — Frontend Developer"
  description="Frontend developer with 3 years of experience building fast, responsive, and user-friendly web interfaces."
>
  <Hero layout="centered" size="sm">
    <Badge slot="badge" variant="brand" pill>
      <Icon name="user" size="sm" />
      About me
    </Badge>
    <h1 slot="title">
      <span class="text-foreground [-webkit-text-fill-color:currentColor]">Nazar Hnatyuk —</span><br />
      <span class="text-brand-500 [-webkit-text-fill-color:var(--color-brand-500)]">
        <TypingEffect words={["Frontend Developer", "React Developer", "Astro Developer", "UI Builder", "Web Developer"]} />
      </span>
    </h1>

    <p slot="description">
      I care about both sides of the craft — how a site looks and how it
      performs. Here's a bit more about how I think and work.
    </p>
  </Hero>
  <!-- What's possible now -->
  <section class="py-[var(--space-section-md)] bg-brand-500/8 dark:bg-background-secondary">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-12 lg:grid-cols-2">
        <!-- Left: text -->
        <div class="flex flex-col gap-4" data-reveal>
          <div class="flex flex-col gap-6">
            <Badge variant="brand" pill class="self-start">My focus</Badge>
            <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
              Building interfaces<br /> that feel clear and fast
            </h2>
          </div>
          <p class="text-lg text-foreground-muted leading-relaxed">
           I'm Nazar Hnatyuk, a frontend developer with 3 years of hands-on experience building responsive websites and web interfaces.
          </p>
          <p class="text-lg text-foreground-muted leading-relaxed">
            I care about clean structure, readable code, smooth interactions, and making sure the final experience works well across screen sizes.
          </p>
        </div>
        <!-- Right: two stacked partner cards -->
        <div class="flex flex-col gap-4 h-full" data-reveal data-reveal-delay="1">
          <Card variant="elevated" hover class="flex-1 flex flex-col justify-center">
            <div class="flex items-start gap-4">
              <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                <Icon name="code-2" size="md" />
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-xs font-bold tracking-wide casesensitive text-foreground-muted mb-1">Frontend Developer</p>
                <h3 class="text-base font-semibold text-foreground">Nazar Hnatyuk</h3>
                <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                  3 years of frontend experience — responsive layouts, component-based development, performance, and clear communication.
                </p>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <Badge size="sm" variant="brand">Astro</Badge>
                  <Badge size="sm" variant="brand">Tailwind</Badge>
                  <Badge size="sm" variant="brand">TypeScript</Badge>
                </div>
              </div>
            </div>
          </Card>
          <Card variant="elevated" hover class="group flex-1 flex flex-col justify-center">
            <div class="flex items-start justify-between gap-4">
              <div class="flex items-start gap-4 flex-1 min-w-0">
                <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
                  <Icon name="sparkles" size="md" />
                </div>
                <div class="flex-1 min-w-0">
                  <p class="text-xs font-bold tracking-wide casesensitive text-foreground-muted mb-1">How I Work</p>
                <h3 class="text-base font-semibold text-foreground">Thoughtful frontend</h3>
                <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                  Planning the structure, building carefully, testing the details, and improving the experience until it feels right.
                </p>
                <div class="flex flex-wrap gap-1.5 mt-3">
                  <Badge size="sm" variant="brand">Responsive UI</Badge>
                  <Badge size="sm" variant="brand">Code quality</Badge>
                  <Badge size="sm" variant="brand">Performance</Badge>
                </div>
              </div>
              </div>
              <Icon name="arrow-up-right" size="sm" class="text-foreground-muted group-hover:text-brand-500 transition-colors shrink-0" />
            </div>
          </Card>
        </div>
      </div>
    </div>
  </section>
  <!-- Values -->
  <section class="py-[var(--space-section-md)] border-t border-border">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mb-8 text-center flex flex-col items-center gap-4" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>My Process</Badge>
          <h2 class="font-display text-4xl font-bold text-foreground">
            How I Work
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          These aren't aspirations — they're the constraints every project is held to, from the first conversation to the final handover.
        </p>
      </div>
      <div class="grid gap-8 md:grid-cols-3" data-reveal data-reveal-delay="1">
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="zap" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Performance First</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Fast sites rank better, convert better, and keep users happy. I optimise for speed from the ground up.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="award" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Experience That Shows</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                3 years of focused frontend work means I know how to turn designs and ideas into practical, polished interfaces.
              </p>
            </div>
          </div>
        </Card>
        <Card hover>
          <div class="flex items-start gap-4">
            <div class="w-11 h-11 rounded-xl bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="rocket" size="md" />
            </div>
            <div class="flex-1 min-w-0">
              <h3 class="text-base font-semibold text-foreground">Modern from the Ground Up</h3>
              <p class="text-sm text-foreground-muted leading-relaxed mt-1.5">
                Built with today's tooling. Fast, maintainable, and ready for whatever comes next.
              </p>
            </div>
          </div>
        </Card>
      </div>
    </div>
  </section>
  <!-- My Stack -->
  <TechStack
    badge="Tools & Tech"
    title="My Stack"
    description="The tools I rely on every day to build fast, modern websites — chosen for performance, great developer experience, and reliability."
  />
  <!-- FAQ -->
  <section class="py-[var(--space-section-md)] bg-background border-t border-border">
    <div class="mx-auto max-w-6xl px-6 flex flex-col gap-8">
      <div class="flex flex-col items-center gap-4 text-center" data-reveal>
        <div class="flex flex-col items-center gap-6">
          <Badge variant="brand" pill>Good to know</Badge>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-foreground">
            Frequently asked questions
          </h2>
        </div>
        <p class="text-lg text-foreground-muted max-w-2xl mx-auto text-balance">
          Some of the questions I get asked most often.
        </p>
      </div>

      <div class="grid gap-6 md:grid-cols-2">
        <!-- Card 1: About Astro -->
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="1">
          <div class="flex items-center gap-3 pb-4 border-b border-border">
            <div class="w-11 h-11 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="rocket" size="md" />
            </div>
            <h3 class="font-display text-base font-semibold text-foreground">About Astro</h3>
          </div>
          <div class="w-full">
            <details class="border-b border-border" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                What is Astro?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Astro is a modern web framework built for content-driven sites. It ships zero JavaScript by default — only sending what the page actually needs. The result is fast load times, excellent Core Web Vitals scores, and lean, maintainable code.
              </div>
            </details>
            <details class="border-b border-border" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Why do you build with Astro?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Because it matches the way I think about the web: lean, purposeful, and built to last. Astro lets me ship fast sites without fighting the framework — minimal JavaScript, clean HTML, great SEO — so I can focus on the design and details that actually matter.
              </div>
            </details>
            <details class="border-b border-border" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Do you always build with Astro?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Almost always. For portfolios, business sites, marketing pages, and blogs, Astro is the right tool. If a project genuinely calls for something different, I'll be upfront about it. But Astro handles most of what clients need, and it does it exceptionally well.
              </div>
            </details>
            <details class="border-b border-border" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                What kind of projects do you like working on?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                I enjoy working on frontend-heavy websites and web apps where the interface matters: landing pages, portfolios, dashboards, product pages, and responsive UI systems.
              </div>
            </details>
            <details class="border-b border-border last:border-0" name="faq-astro">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                What are you improving next?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                I'm always improving my frontend skills: cleaner architecture, better accessibility, smoother interactions, and stronger real-world project delivery.
              </div>
            </details>
          </div>
        </Card>

        <!-- Card 2: About the work -->
        <Card variant="elevated" padding="lg" data-reveal data-reveal-delay="2">
          <div class="flex items-center gap-3 pb-4 border-b border-border">
            <div class="w-11 h-11 rounded-lg bg-gradient-to-br from-brand-500/20 to-brand-500/5 flex items-center justify-center text-brand-500 shrink-0">
              <Icon name="user" size="md" />
            </div>
            <h3 class="font-display text-base font-semibold text-foreground">About the work</h3>
          </div>
          <div class="w-full">
            <details class="border-b border-border" name="faq-work">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Do you use modern tools when you build?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Yes. I use modern frontend tooling to move faster and keep quality high, but the decisions, implementation, and final result are still handled carefully by me.
              </div>
            </details>
            <details class="border-b border-border" name="faq-work">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Are you a company or agency?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                No. I'm a frontend developer working independently. You work directly with me, from the first conversation to the final delivery.
              </div>
            </details>
            <details class="border-b border-border" name="faq-work">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                How do you choose which projects to take on?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                I look for projects with a clear goal, a useful interface to build, and room to care about quality. I work best with clear communication and practical expectations.
              </div>
            </details>
            <details class="border-b border-border" name="faq-work">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Do you offer support or maintenance after launch?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Yes. Whether it's small updates, content changes, or something more involved — I'm available after launch. We can agree on whatever arrangement works best for the project.
              </div>
            </details>
            <details class="border-b border-border last:border-0" name="faq-work">
              <summary class="flex w-full items-center justify-between text-sm py-4 text-left font-medium text-foreground transition-colors hover:text-foreground-secondary cursor-pointer list-none [&::-webkit-details-marker]:hidden">
                Do you work remotely?
                <Icon name="chevron-down" size="sm" class="faq-icon shrink-0 text-foreground-muted transition-transform duration-200" />
              </summary>
              <div class="pb-4 text-sm text-foreground-muted leading-relaxed">
                Yes. I'm based in Kyiv, Ukraine, and can work remotely with clients and teams in different locations.
              </div>
            </details>
          </div>
        </Card>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-[var(--space-section-md)] bg-background-secondary border-t border-border">
    <div class="mx-auto max-w-2xl px-6 text-center" data-reveal>
      <h2 class="font-display text-4xl font-bold text-foreground mb-4 text-balance">
        Sound like a good fit?
      </h2>
      <p class="text-lg text-foreground-muted mb-8 text-balance">
        If my background and approach match what you're looking for, I'm open to new projects. Let's have a conversation.
      </p>
      <Button size="lg" href="/contact">
        Start a Project
        <Icon name="arrow-right" size="sm" />
      </Button>
    </div>
  </section>
</PageLayout>

<style>
  details[open] > summary .faq-icon {
    transform: rotate(180deg);
  }
</style>
